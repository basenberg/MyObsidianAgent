# =============================================================================
# Application Configuration
# =============================================================================

APP_NAME=Obsidian Agent Project
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS - allowed origins for cross-origin requests
# Must be a JSON array format (with double quotes)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","app://obsidian.md","capacitor://localhost"]

# =============================================================================
# LLM Configuration (required)
# =============================================================================

LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_KEY=sk-ant-...

# =============================================================================
# API Authentication (required)
# =============================================================================

# Bearer token for Obsidian Copilot — set to any secret string
API_KEY=your-secret-api-key

# =============================================================================
# Database Configuration (optional — not required for agent)
# =============================================================================

# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/obsidian_db
